{
  "name": "execEngineBackend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "dev": "nodemon --watch src --ext ts --exec node --loader ts-node/esm src/index.ts",
    "dev:worker": "nodemon --watch src --ext ts --exec node --loader ts-node/esm src/worker.ts"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bullmq": "^5.67.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.4",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "morgan": "^1.10.1",
    "pg": "^8.18.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
